OPENSHIFT_AIOPS_ENVIRONMENT=development
OPENSHIFT_AIOPS_CLUSTER=
OPENSHIFT_AIOPS_CONTEXT=
OPENSHIFT_AIOPS_KUBECONFIG=${HOME}/.kube/config
OPENSHIFT_AIOPS_OUTPUT_DIR=./evidencias
OPENSHIFT_AIOPS_TIMEOUT=60
OPENSHIFT_AIOPS_LOG_TAIL=300
OPENSHIFT_AIOPS_MAX_OUTPUT_BYTES=1048576
OPENSHIFT_AIOPS_REQUIRE_PRODUCTION_CONFIRMATION=true
OPENSHIFT_AIOPS_SANITIZE=true
OPENSHIFT_AIOPS_AUDIT_LOG=./logs/audit.jsonl
